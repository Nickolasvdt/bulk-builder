# Obrigatório — chave da API da Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Opcional — modelo padrão é claude-haiku-4-5-20251001
# Para maior qualidade use claude-sonnet-4-6
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Opcional — diretório de storage (padrão: ./data/sites)
# Em Vercel/serverless, use: /tmp/sites
# STORAGE_DIR=/tmp/sites
