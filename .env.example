# Obrigatório — chave gratuita em: aistudio.google.com > Get API Key
GEMINI_API_KEY=AIza...

# Opcional — modelo padrão é gemini-2.0-flash (gratuito e rápido)
GEMINI_MODEL=gemini-2.0-flash

# Opcional — diretório de storage (padrão: ./data/sites)
# Em Vercel/serverless use: /tmp/sites
# STORAGE_DIR=/tmp/sites
